	from products p
	join sales s
	on p.product_id = s.product_id
	group by p.product_id, p.product_name
)
select product_id, product_name, total_qty_sold
from total_quantity_sold 
where total_qty_sold > (select avg(total_qty_sold) from total_quantity_sold);

-- 66. Create an intermediate result that calculates total spending per customer,
--     then determine which customers spent more than the average spending.
select * from customers;
select * from sales;

with total_spending as (
	select c.customer_id, c.first_name, c.last_name, sum(total_amount) as total_spend
	from customers c
	join sales s
	on c.customer_id = s.customer_id
	group by c.customer_id, c.first_name, c.last_name
)
select first_name, last_name, total_spend
