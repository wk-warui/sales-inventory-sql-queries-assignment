select * from sales;

with total_revenue as (
	select p.product_id, p.product_name, sum(s.total_amount) as total_rev
	from products p
	join sales s
	on p.product_id = s.product_id
	group by p.product_id, p.product_name
)
select product_id, product_name, total_rev
